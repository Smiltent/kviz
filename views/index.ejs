
<div class="loginRegContainer">
    <div>
        <h1>login</h1>
        <form action="/auth/login" method="POST" class="qBox flex">
            <input type="text" name="username" placeholder="Username">
            <input type="password" name="password" placeholder="Password">
            <input type="submit" value="Login">
        </form>

        <% if (typeof loginErrors !== 'undefined' && loginErrors) { %>
            <% for (let error of loginErrors) { %>
                <p class="red"><%= error %></p>
            <% } %>
        <% } %>
    </div>

    <div>
        <h1>register</h1>
        <form action="/auth/register" method="POST" class="qBox flex">
            <input type="text" name="username" placeholder="Username">
            <input type="password" name="password" placeholder="Password">
            <input type="submit" value="Register">
        </form>
        <% if (typeof registerErrors !== 'undefined' && registerErrors) { %>
            <% for (let error of registerErrors) { %>
                <p class="red"><%= error %></p>
            <% } %>
        <% } %>
    </div>

    <!-- these are placed here temporarily, accounts with these passwords and usernames are not created automatically -->
    <p>psst... hey! the admin password is admin1</p>
    <p>psst... hey! the user password is user11</p>
</div>


