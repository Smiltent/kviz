
<h1>Login</h1>

<form action="/auth/login" method="POST">
    <input type="text" name="username">
    <input type="password" name="password">
    <input type="submit" value="Login">

    <% if (typeof errors !== 'undefined' && errors) { %>
        <% errors.forEach(e => { %>
            <p><%= e %></p>
        <% }) %>
    <% } %>
</form>