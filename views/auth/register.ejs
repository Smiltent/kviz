
<h1>Register</h1>

<form action="/auth/register" method="POST">
    <input type="text" name="username">
    <input type="password" name="password">
    <input type="submit" value="Register">

    <% if (typeof errors !== 'undefined' && errors) { %>
        <% errors.forEach(e => { %>
            <p><%= e %></p>
        <% }) %>
    <% } %>
</form>