
<div class="quiz">
    <div class="qProgress">
        <div class="qProgressTrack">
            <div id="quizProgressBar" class="qProgressFill" role="progressbar" aria-valuenow="0" aria-valuemin="0" aria-valuemax="100" style="width: 0%;"></div>
        </div>
    </div>

    <div class="header">
        <h1 id="quizQuestion"></h1>
    </div>

    <div id="quizAnswers"></div>
    <p class="red" id="quizError" role="alert"></p>
</div>

<script src="/public/js/quiz.js"></script>
<script>init(<%- questions %>, "<%= quizid %>")</script>