
<div class="header flex">
    <div class="hTitle flex">
        <h1>create quiz</h1>
        <a href="/admin">admin page</a>
    </div>

    <div class="hUser flex">
        <p>hello, <%= user.username %>!</p>

        <form action="/auth/logout" method="POST">
            <input type="submit" value="Logout">
        </form> 
    </div>
</div>

<form id="qForm" action="/admin/create" method="POST">
    <input type="text" name="title" placeholder="Quiz Title" required>
    <div id="qContainer"></div>

    <input type="hidden" name="questions" id="qInput" required>

    <% if (typeof createErrors !== 'undefined' && createErrors) { %>
        <% for (let error of createErrors) { %>
            <p class="red"><%= error %></p>
        <% } %>
    <% } %>

    <br>
    <button type="button" id="qAddButton" class="betterBtn">Add Question</button>
    <input type="submit" value="Create Quiz">
</form>

<script src="/public/js/createQuiz.js"></script>