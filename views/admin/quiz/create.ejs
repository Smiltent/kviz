<h1>Create Quiz</h1>

<form id="qForm" action="/admin/quiz/create" method="POST">
    <input type="text" name="title" placeholder="Quiz title" required>
    <div id="qContainer"></div>

    <button type="button" id="qAddButton">Add Question</button>
    <input type="hidden" name="questions" id="qInput">

    <br><br>
    <input type="submit" value="Create Quiz">
</form>

<script src="/public/js/createQuiz.js"></script>